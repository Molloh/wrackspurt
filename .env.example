# All values below are FALLBACKS — they are only used when the matching
# entry in the in-app Settings page (/settings) is not configured.
# Settings written through the UI live in SQLite (`settings` table).

# --- NotebookLM (notebooklm-py CLI) ---
# NOTEBOOKLM_BIN=notebooklm
# NOTEBOOKLM_HOME=
# NOTEBOOKLM_PROFILE=default
# NOTEBOOKLM_AUTH_JSON=

# --- Gemini (Google AI Studio) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_ENDPOINT=https://generativelanguage.googleapis.com

# --- Storage ---
# WRACKSPURT_DB_URL=file:./data/wrackspurt.db
# WRACKSPURT_DB_PATH=./data/wrackspurt.db

# --- Optional: OpenAI-compatible model (legacy stub) ---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
