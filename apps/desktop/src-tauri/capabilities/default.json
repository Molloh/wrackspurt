{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Default capability for the main window. Allows the bundled sidecar (node) to be spawned via tauri-plugin-shell.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "node",
          "cmd": "node",
          "args": true,
          "sidecar": false
        }
      ]
    }
  ]
}
